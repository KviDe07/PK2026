# Скопируйте этот файл в .env и заполните реальными значениями.
# .env в репозиторий не коммитится (см. .gitignore).

# Входящий вебхук Битрикс24.
# Формат: https://<ваш-портал>.bitrix24.ru/rest/<id_пользователя>/<токен>/
BITRIX_WEBHOOK_URL=https://example.bitrix24.ru/rest/1/xxxxxxxxxxxxxxxx/

# Логин/пароль веб-приложения (HTTP Basic).
# Если APP_PASSWORD не задан — вход НЕ требуется (только для локальной разработки).
# На сервере ОБЯЗАТЕЛЬНО задайте пароль.
APP_USERNAME=admin
APP_PASSWORD=

# Под-путь, если приложение живёт не в корне домена, а за nginx (напр. /pk2026).
# Пусто = работает в корне (локально). На сервере fakt.mipt.ru: APP_URL_PREFIX=/pk2026
APP_URL_PREFIX=
